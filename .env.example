# ============================================================
# AlphaBot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Binance API Keys ---
# Mainnet (read-only, for price data — public endpoints need no auth)
BINANCE_MAINNET_API_KEY=
BINANCE_MAINNET_SECRET=

# Testnet (for order placement)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Environment ---
# testnet or mainnet (NEVER set mainnet until Phase 5)
ENVIRONMENT=testnet

# --- Trading Parameters ---
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT
PRIMARY_TIMEFRAME=15m
CANDLE_LOOKBACK=200

# --- Risk Parameters ---
RISK_PER_TRADE_PCT=0.5
MAX_RISK_PER_TRADE_PCT=2.0
DAILY_LOSS_CAP_PCT=2.0
MAX_DRAWDOWN_PCT=5.0
MAX_CONCURRENT_POSITIONS=3
MAX_LEVERAGE=5
MIN_SIGNAL_CONFIDENCE=68
MIN_RISK_REWARD=1.5

# --- Strategy Parameters ---
ATR_SL_MULTIPLIER=1.5
ATR_TP_MULTIPLIER=3.0
TRAILING_STOP_ACTIVATION_R=1.0
EMA_FAST=20
EMA_SLOW=50

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

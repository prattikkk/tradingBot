# ============================================================
# AlphaBot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Binance API Keys ---
# Mainnet (read-only, for price data — public endpoints need no auth)
BINANCE_MAINNET_API_KEY=
BINANCE_MAINNET_SECRET=

# Testnet (for order placement)
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_testnet_secret_here

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Environment ---
# testnet or mainnet (NEVER set mainnet until Phase 5)
ENVIRONMENT=testnet

# NOTE:
# Keep strategy/risk/timeframe tuning in config.yaml.
# Defining those same keys in .env overrides YAML and can hide live settings drift.

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
